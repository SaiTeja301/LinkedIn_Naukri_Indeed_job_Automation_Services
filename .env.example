# ==============================================================================
# Job Automation Service — Environment Variable Template
# ==============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit the .env file to source control
#   4. The .env file is already listed in .gitignore
# ==============================================================================

# ── MySQL Database ─────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/job_automation_db
SPRING_DATASOURCE_USERNAME=your_db_username_here
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# ── Gemini AI API ──────────────────────────────────────────────────────────────
# Obtain from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Selenium Configuration ──────────────────────────────────────────
# Set to true to run Chrome headlessly (recommended for CI/server environments)
SELENIUM_HEADLESS=false

# ── Optional: Naukri Scraping ──────────────────────────────────────────────────
# Default maximum search-result pages to scrape per keyword (overridden per request)
NAUKRI_MAX_PAGES=5
